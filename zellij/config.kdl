keybinds clear-defaults=true {
    normal {
        // Navegación entre paneles (como LazyVim)
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
        bind "Alt l" { MoveFocus "Right"; }

        // Modos principales
        bind "Alt w" { SwitchToMode "Pane"; }
        bind "Alt b" { SwitchToMode "Tab"; }
        bind "Alt s" { SwitchToMode "Scroll"; }

        // Navegación rápida entre tabs
        bind "Alt H" { GoToPreviousTab; }
        bind "Alt L" { GoToNextTab; }

        // Operaciones de cierre
        bind "Alt q" { CloseFocus; }
        bind "Alt Q" { CloseTab; }

        // Maximizar/Zoom
        bind "Alt z" { ToggleFocusFullscreen; }
    }

    pane {
        // Navegación
        bind "h" { MoveFocus "Left"; }
        bind "j" { MoveFocus "Down"; }
        bind "k" { MoveFocus "Up"; }
        bind "l" { MoveFocus "Right"; }
        
        // Splits
        bind "v" { NewPane "Right"; }
        bind "s" { NewPane "Down"; }
        
        // Redimensionar
        bind "H" { Resize "Left"; }
        bind "J" { Resize "Down"; }
        bind "K" { Resize "Up"; }
        bind "L" { Resize "Right"; }

        // Panel flotante
        bind "f" { ToggleFloatingPanes; }
        bind "F" { TogglePaneFrames; }  // Toggle bordes del panel
        
        // Salir del modo
        bind "q" { SwitchToMode "Normal"; }
        bind "Esc" { SwitchToMode "Normal"; }
    }

    tab {
        // Navegación
        bind "h" { GoToPreviousTab; }
        bind "l" { GoToNextTab; }
        
        // Gestión de tabs
        bind "n" { NewTab; }
        bind "d" { CloseTab; }
        bind "r" { SwitchToMode "RenameTab"; }
        
        // Salir del modo
        bind "q" { SwitchToMode "Normal"; }
        bind "Esc" { SwitchToMode "Normal"; }
    }

    scroll {
        // Navegación
        bind "j" { ScrollDown; }
        bind "k" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "G" { ScrollToBottom; }
        bind "g" { ScrollToTop; }
        
        // Búsqueda
        bind "/" { SearchInput; }
        bind "n" { Search "down"; }
        bind "N" { Search "up"; }
        
        // Salir del modo
        bind "q" { SwitchToMode "Normal"; }
        bind "Esc" { SwitchToMode "Normal"; }
    }

    renametab {
        bind "Esc" { SwitchToMode "Normal"; }
        bind "Enter" { SwitchToMode "Normal"; }
    }
}

default_layout "work"


theme "catppuccin-latte"
